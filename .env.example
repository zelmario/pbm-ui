# Generate a strong random key: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Default admin credentials (used on first startup only)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin

# Only needed when MongoDB runs on the same Docker host.
# Used with: docker compose -f docker-compose.yml -f docker-compose.network.yml up --build -d
# Find it with: docker inspect <container> --format '{{range $k, $v := .NetworkSettings.Networks}}{{$k}}{{end}}'
# PBM_DOCKER_NETWORK=your-mongodb-network
